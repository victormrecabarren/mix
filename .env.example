# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, never in app

# ─── Spotify ──────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your-spotify-client-id           # safe to expose in app
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret   # server-side only

# ─── Apple MusicKit ───────────────────────────────────────────────────────────
MUSICKIT_KEY_ID=your-musickit-key-id
MUSICKIT_TEAM_ID=your-apple-team-id
MUSICKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
